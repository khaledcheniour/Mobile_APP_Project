<?xml version="1.0" encoding="utf-8"?>
<!-- Shared sidebar layout — included in both map and list fragments -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sidebar_container"
    android:layout_width="280dp"
    android:layout_height="match_parent"
    android:layout_gravity="start"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:elevation="8dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#16213E"
        android:paddingTop="40dp"
        android:paddingBottom="16dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="👥 Friends"
            android:textColor="#E0E0FF"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Check to show their memories"
            android:textColor="#888AAA"
            android:textSize="13sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A4A" />

    <!-- Friends list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/friends_recycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipToPadding="false" />

    <!-- Close button at bottom -->
    <TextView
        android:id="@+id/btn_close_sidebar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="✕  Close"
        android:textColor="#888AAA"
        android:textSize="14sp"
        android:gravity="center"
        android:background="#0F0F1E"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
